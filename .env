# Single source of truth for values shared between scripts/infra/docker-compose*.yml,
# scripts/deploy.sh, scripts/database/reset.sh, marketplace-app/application-dev.yml, and
# integration-tests' Testcontainers-based repository tests (AbstractPostgresIntegrationTest).
# Docker Compose reads this file automatically from the current working directory. Non-secret,
# dev-only values only -- see backlog/completed/issues/improvement-044-shared-env-config-consolidation.md.
POSTGRES_IMAGE=postgres:15-alpine
DB_NAME=experiments
DB_USER=experiments_user
DB_PASSWORD=experiments_user_password
DB_PORT=5432
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin12345
S3_BUCKET=advertisement
S3_REGION=us-east-1
S3_PORT=9000
