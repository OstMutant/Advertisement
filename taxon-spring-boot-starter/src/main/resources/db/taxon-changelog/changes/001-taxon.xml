<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="taxon-001" author="taxon-starter">

        <!-- ── taxon ────────────────────────────────────────────────────── -->
        <createTable tableName="taxon">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(64)"/>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="deleted_by" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="BIGINT"/>
            <column name="updated_by" type="BIGINT"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_taxon_type_deleted_at" tableName="taxon">
            <column name="type"/>
            <column name="deleted_at"/>
        </createIndex>

        <!-- Partial unique index — only enforced when code is non-null -->
        <sql>
            CREATE UNIQUE INDEX uidx_taxon_type_code ON taxon (type, code) WHERE code IS NOT NULL;
        </sql>

        <!-- ── taxon_translation ─────────────────────────────────────────── -->
        <createTable tableName="taxon_translation">
            <column name="taxon_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_taxon_translation_taxon"
                             references="taxon(id)"
                             deleteCascade="true"/>
            </column>
            <column name="locale" type="VARCHAR(8)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(2000)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="taxon_translation"
                       columnNames="taxon_id, locale"
                       constraintName="pk_taxon_translation"/>

        <createIndex indexName="idx_taxon_translation_locale_name" tableName="taxon_translation">
            <column name="locale"/>
            <column name="name"/>
        </createIndex>

        <!-- ── taxon_assignment ──────────────────────────────────────────── -->
        <createTable tableName="taxon_assignment">
            <column name="entity_type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="taxon_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_taxon_assignment_taxon"
                             references="taxon(id)"/>
            </column>
            <column name="assigned_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="assigned_by" type="BIGINT"/>
        </createTable>

        <addPrimaryKey tableName="taxon_assignment"
                       columnNames="entity_type, entity_id, taxon_id"
                       constraintName="pk_taxon_assignment"/>

        <createIndex indexName="idx_taxon_assignment_taxon_id" tableName="taxon_assignment">
            <column name="taxon_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
