  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "docker image prune -f 2>/dev/null || true",
            "if": "Bash(docker build *)",
            "statusMessage": "Cleaning dangling Docker images...",
            "async": true
          },
          {
            "type": "command",
            "command": "docker container prune -f 2>/dev/null || true",
            "if": "Bash(docker rm *)",
            "statusMessage": "Cleaning stopped containers...",
            "async": true
          },
          {
            "type": "command",
            "command": "docker container prune -f 2>/dev/null || true",
            "if": "Bash(bash /app/playwright/run.sh *)",
            "statusMessage": "Cleaning stopped containers...",
            "async": true
          }
        ]
      }
    ]
