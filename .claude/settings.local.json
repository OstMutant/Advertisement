{
  "permissions": {
    "allow": [
      "Bash(docker run *)",
      "Bash(docker cp *)",
      "Bash(docker exec *)",
      "Bash(docker rm *)",
      "Bash(bash /app/playwright/run.sh filter-advertisements --ux)",
      "Bash(bash /app/playwright/run.sh filter-users --ux)",
      "Bash(bash /app/playwright/run.sh upload-image --ux)",
      "Bash(bash /app/playwright/run.sh upload-gallery --ux)",
      "Bash(apt-get install *)",
      "Bash(psql -h localhost -U experiments_user -d postgres -c ' *)",
      "Bash(bash *)",
      "Bash(PGPASSWORD=experiments_user_password psql *)",
      "Bash(docker build *)",
      "Bash(curl -s \"http://localhost:8080/\")",
      "Bash(curl -s \"http://localhost:8080/VAADIN/build/indexhtml-ChMj0KPN.css\")",
      "Bash(sort -k6,7)",
      "Bash(xargs cat *)",
      "Bash(docker system *)",
      "Bash(docker image *)",
      "Bash(sort -k2 -h)",
      "Bash(docker container ls *)",
      "Bash(docker builder prune *)",
      "Bash(docker buildx prune *)",
      "Bash(echo \"EXIT: $?\")",
      "Bash(psql -h localhost -U experiments_user -d experiments -c ' *)",
      "Bash(echo \"exit: $?\")",
      "Bash(sort -t: -k2 -rn)",
      "Bash(python3 *)",
      "Bash(xargs ls *)",
      "Bash(xargs -I{} basename {} .js)",
      "Bash(git *)",
      "Bash(psql -h localhost -U experiments_user -d experiments -c \"DROP TABLE IF EXISTS advertisement_snapshot, user_snapshot, databasechangelog, databasechangeloglock CASCADE;\")",
      "Bash(xargs -r docker rmi --force)",
      "Skill(update-config)",
      "Bash(docker volume *)",
      "Bash(docker container prune *)",
      "Bash(grep -v \"^\\\\[ERROR\\\\] $\")",
      "Bash(wait)",
      "Bash(apt-get update *)",
      "Bash(unzip -l /tmp/app.jar)",
      "Bash(grep -E \"\\\\.java$\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "docker image prune -f 2>/dev/null || true",
            "if": "Bash(docker build *)",
            "statusMessage": "Cleaning dangling Docker images...",
            "async": true
          },
          {
            "type": "command",
            "command": "docker container prune -f 2>/dev/null || true",
            "if": "Bash(docker rm *)",
            "statusMessage": "Cleaning stopped containers...",
            "async": true
          },
          {
            "type": "command",
            "command": "docker container prune -f 2>/dev/null || true",
            "if": "Bash(bash /app/playwright/run.sh *)",
            "statusMessage": "Cleaning stopped containers...",
            "async": true
          }
        ]
      }
    ]
  }
}
