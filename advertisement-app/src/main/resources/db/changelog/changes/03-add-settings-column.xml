<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="03-1-add-settings-column-nullable" author="ost">
        <addColumn tableName="user_information">
            <column name="settings" type="JSONB"/>
        </addColumn>
    </changeSet>

    <changeSet id="03-2-backfill-default-settings" author="ost">
        <sql>
            UPDATE user_information
            SET settings = '{"adsPageSize":20,"usersPageSize":20}'::jsonb
            WHERE settings IS NULL;
        </sql>
    </changeSet>

    <changeSet id="03-3-settings-not-null" author="ost">
        <addNotNullConstraint
                tableName="user_information"
                columnName="settings"
                columnDataType="JSONB"
                defaultNullValue='{"adsPageSize":20,"usersPageSize":20}'/>
    </changeSet>

</databaseChangeLog>
